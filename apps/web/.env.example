# ── Kết nối backend API ────────────────────────────────────
# URL gốc của backend NestJS (server-side, không expose ra client)
API_BASE_URL=http://localhost:4000/api

# ── On-demand revalidation (admin gọi sau khi đổi nội dung) ─
# Secret dùng chung với admin-dev; admin POST tới /api/revalidate kèm secret này
WEB_REVALIDATE_SECRET=doi-thanh-chuoi-bi-mat-revalidate

# ── SEO / site ─────────────────────────────────────────────
# URL công khai của website (dùng cho metadata OG, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://inchemminhhien.com.vn
