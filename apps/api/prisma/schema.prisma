// Prisma schema — Website Sơn INCHEM (Minh Hiền)
// Data model: AdminUser, Product, Post, Color, Lead

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductGroup {
  PU_INDOOR // Sơn PU trong nhà
  PU_OUTDOOR // Sơn PU ngoài trời
  NC // Sơn NC
  UV // Sơn UV
  OTHER // Sản phẩm khác
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum ColorTone {
  WARM // Tông ấm
  LIGHT // Tông sáng
  DARK // Tông tối
  COOL // Tông lạnh
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  DONE
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model Product {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  group       ProductGroup
  gloss       String? // độ bóng, vd "10%", "30%", "90%"
  description String?
  image       String?
  status      ContentStatus @default(PUBLISHED)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([group])
  @@index([order])
  @@map("products")
}

model Post {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  excerpt     String?
  content     String // HTML/markdown
  thumbnail   String?
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, publishedAt])
  @@map("posts")
}

model Color {
  id        String    @id @default(cuid())
  code      String // vd "SW 6814"
  name      String // vd "Breathtaking"
  tone      ColorTone
  image     String?
  hex       String? // mã màu hiển thị nếu không có ảnh
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tone])
  @@index([order])
  @@map("colors")
}

model Lead {
  id        String     @id @default(cuid())
  fullName  String
  phone     String
  email     String?
  address   String?
  message   String?
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status, createdAt])
  @@map("leads")
}
