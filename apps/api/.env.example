# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Domain FE được phép gọi API (CORS), phân tách bằng dấu phẩy
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/inchem?schema=public"

# ── Auth (JWT admin) ───────────────────────────────────────
JWT_SECRET=doi-thanh-chuoi-bi-mat-that-dai-ngau-nhien
JWT_EXPIRES_IN=7d
# Tài khoản admin khởi tạo bằng seed
ADMIN_EMAIL=admin@inchemminhhien.com.vn
ADMIN_PASSWORD=123456
ADMIN_NAME=Quản trị Minh Hiền

# ── Email (Resend HTTP API) — nhận thông báo lead ──────────
# Dùng Resend thay SMTP vì Railway chặn cổng SMTP outbound (25/465/587).
# Tạo API key tại https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# From: bắt buộc thuộc domain đã verify trên Resend.
# Chưa verify domain riêng → tạm dùng onboarding@resend.dev.
MAIL_FROM="Website Minh Hiền <no-reply@inchemminhhien.com.vn>"
# Người nhận thông báo lead
MAIL_TO=hienminh2011@gmail.com

# ── Upload ảnh (Cloudflare R2) ─────────────────────────────
# Account ID Cloudflare (Dashboard → R2) — dùng để dựng endpoint API
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=inchem-uploads
# Access Key ID / Secret của R2 API Token (R2 → Manage API Tokens)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Thư mục (prefix) chứa ảnh trong bucket
R2_FOLDER=inchem
# Domain công khai để đọc ảnh: bật "Public Development URL" (*.r2.dev) hoặc gắn custom domain.
# Bắt buộc để URL ảnh trả về truy cập được. KHÔNG kèm dấu / ở cuối.
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
